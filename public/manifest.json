{
  "$schema": "https://json.schemastore.org/web-manifest",
  "name": "Passport Photo Maker",
  "short_name": "Passport Photo",
  "description": "Create professional passport photos instantly. AI background removal, country templates, and printable sheets.",
  "icons": [
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "theme_color": "#ffffff",
  "background_color": "#ffffff",
  "display": "standalone",
  "start_url": ".",
  "orientation": "portrait-primary",
  "categories": ["photo", "utility"]
}
